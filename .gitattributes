# Text files with normalized line endings (standard for Jekyll projects)
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.svg text eol=lf
*.scss text eol=lf
*.rb text eol=lf

# 3D model files tracked by Git LFS
*.glb filter=lfs diff=lfs merge=lfs -text
*.gltf filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.stl filter=lfs diff=lfs merge=lfs -text

# Web images are committed as plain Git blobs, NOT Git LFS.
# GitHub Pages "deploy from a branch" builds Jekyll itself and does not resolve
# LFS pointers, so an LFS-tracked image would deploy as broken pointer text.
# These files are small; keep them inline. Reserve LFS for large, non-served
# source art only (see psd/ai below).
*.png -text
*.jpg -text
*.jpeg -text
*.gif -text
*.tiff -text
*.bmp -text
*.webp -text

# Video files tracked by Git LFS
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.mkv filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text

# Small served homepage preview: must be a plain Git blob for GitHub Pages.
assets/media/alis-trailer-loop.mp4 -filter -diff -merge -text

# Audio files tracked by Git LFS
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
*.flac filter=lfs diff=lfs merge=lfs -text

# Font files tracked by Git LFS
*.eot filter=lfs diff=lfs merge=lfs -text
*.ttf filter=lfs diff=lfs merge=lfs -text
*.woff filter=lfs diff=lfs merge=lfs -text
*.woff2 filter=lfs diff=lfs merge=lfs -text
*.otf filter=lfs diff=lfs merge=lfs -text

# Archive files tracked by Git LFS
*.zip filter=lfs diff=lfs merge=lfs -text
*.gz filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
*.bz2 filter=lfs diff=lfs merge=lfs -text
*.7z filter=lfs diff=lfs merge=lfs -text

# Miscellaneous large binary files
*.psd filter=lfs diff=lfs merge=lfs -text
*.ai filter=lfs diff=lfs merge=lfs -text
